{
  "waitUntil": "networkidle2",
  "navigationTimeoutMs": 10000,
  "waitForSelector": null,
  "waitForSelectorTimeoutMs": 10000,
  "minTextLength": 120,
  "titleSelector": "h1",
  "contentSelectors": [
    "article",
    "[role=\"main\"]",
    "main",
    ".post-content",
    ".entry-content",
    "#content",
    ".content"
  ],
  "removeSelectors": [
    "script",
    "style",
    "noscript",
    "iframe",
    "nav",
    "footer",
    "header",
    "[role=\"navigation\"]",
    ".advertisement",
    ".ad"
  ],
  "plugins": ["lazy-src-img", "strip-img-and-links"]
}
